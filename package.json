{
  "name": "teamsecho",
  "version": "1.1.3",
  "description": "Microsoft Teams 桌面自动化辅助工具",
  "main": "src/main.js",
  "author": "",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron ."
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.teamsecho.app",
    "productName": "TeamsEcho",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        "zip"
      ],
      "identity": null,
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "zip"
      ],
      "icon": "build/icon.png"
    },
    "asar": true
  }
}